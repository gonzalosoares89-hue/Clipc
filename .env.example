# Database
DATABASE_URL="postgresql://user:password@localhost:5432/clipc"

# Redis (job queue)
REDIS_URL="redis://localhost:6379"

# API Keys
ANTHROPIC_API_KEY="sk-ant-..."
UPLOADTHING_API_KEY="..."
UPLOADTHING_APP_ID="..."

# S3/R2 Storage
S3_BUCKET="clipc-videos"
S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."

# TikTok OAuth
TIKTOK_CLIENT_ID="..."
TIKTOK_CLIENT_SECRET="..."
TIKTOK_REDIRECT_URI="https://yourdomain.com/auth/tiktok/callback"

# Email (for magic links)
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="onboarding@resend.dev"
SMTP_PASS="re_..."
SMTP_FROM_EMAIL="noreply@clipc.app"

# Auth
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="$(openssl rand -hex 32)"

# Environment
NODE_ENV="development"
LOG_LEVEL="debug"

# Feature flags
ENABLE_AUTO_PUBLISH="false"
DRAFT_MODE_ONLY="true"
MAX_CLIPS_PER_UPLOAD="20"
MAX_VOD_DURATION_MINUTES="180"
